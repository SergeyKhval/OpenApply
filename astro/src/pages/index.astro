---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div id="root">
    <div
      class="bg-background text-foreground antialiased"
    >
      <div>
        <Header />
        <section
          class="relative flex min-h-screen items-center justify-center overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-primary/15 via-background to-secondary/20"
          ></div>
          <div
            class="pointer-events-none absolute -left-32 top-24 h-64 w-64 rounded-full bg-primary/30 blur-3xl"
          ></div>
          <div
            class="pointer-events-none absolute bottom-12 right-6 h-72 w-72 rounded-full bg-accent/25 blur-3xl"
          ></div>
          <div class="container mx-auto px-4 py-20 relative z-10">
            <div class="flex flex-col gap-8 items-center">
              <h1
                class="bg-linear-to-r from-primary via-foreground to-primary bg-clip-text text-transparent text-5xl lg:text-6xl font-bold leading-tight tracking-tight drop-shadow-sm text-center"
              >
                47 open tabs, 3 spreadsheets, and no idea where you applied?
              </h1>
              <p class="text-xl text-muted-foreground max-w-2xl text-center">
                OpenApply replaces all of that. Paste a job link and the company, role, and details are filled in seconds. Get AI resume reviews matched to each role. Everything in one place.
              </p>
              <div class="w-full max-w-5xl">
                <div class="relative rounded-xl border border-border/40 shadow-2xl shadow-primary/20 overflow-hidden">
                  <picture>
                    <source media="(min-width: 768px)" srcset="/images/dashboard-hero.png" width="1700" height="450" />
                    <img
                      src="/images/dashboard-mobile.png"
                      alt="OpenApply dashboard showing job applications with status tracking"
                      class="w-full h-auto"
                      loading="eager"
                      width="390"
                      height="700"
                    />
                  </picture>
                  <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-background to-transparent"></div>
                </div>
              </div>
              <div class="flex flex-col items-center gap-3">
                <div class="flex items-center gap-4">
                  <a
                    href="/app"
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary text-primary-foreground hover:bg-primary/90 h-11 rounded-md px-8 bg-linear-to-r from-primary via-foreground to-primary hover:opacity-90 transition-opacity shadow-lg shadow-primary/40"
                  >
                    Get Started Free<svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-arrow-right ml-2 w-4 h-4"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                  </a>
                </div>
                <p class="text-sm text-muted-foreground">Free to track. No subscription.</p>
              </div>
            </div>
          </div>
        </section>
        <!-- How It Works Section -->
        <section id="how-it-works" class="relative py-24 scroll-mt-16">
          <div class="absolute inset-0 -z-10 bg-muted/40"></div>
          <div
            class="absolute inset-x-0 top-0 -z-10 h-px bg-linear-to-r from-transparent via-border to-transparent"
          ></div>
          <div class="container mx-auto relative px-4">
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-4">
                How It Works
              </h2>
              <p class="text-xl text-muted-foreground">
                Get set up in under five minutes.
              </p>
            </div>
            <div class="grid lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
              <div class="text-center space-y-4">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-primary/40 bg-primary/10 mx-auto">
                  <span class="text-2xl font-bold text-primary">1</span>
                </div>
                <h3 class="text-xl font-semibold">Import your spreadsheet</h3>
                <p class="text-muted-foreground">
                  Bring your current tracking file and keep your history intact.
                </p>
              </div>
              <div class="text-center space-y-4">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-primary/40 bg-primary/10 mx-auto">
                  <span class="text-2xl font-bold text-primary">2</span>
                </div>
                <h3 class="text-xl font-semibold">Paste a job link</h3>
                <p class="text-muted-foreground">
                  We parse the page and fill in the role, company, and key details in seconds.
                </p>
              </div>
              <div class="text-center space-y-4">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-primary/40 bg-primary/10 mx-auto">
                  <span class="text-2xl font-bold text-primary">3</span>
                </div>
                <h3 class="text-xl font-semibold">Get an AI resume review</h3>
                <p class="text-muted-foreground">
                  Check how your resume stacks up against the job. Generate a cover letter if you want one.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Features Section -->
        <section id="features" class="relative py-24 scroll-mt-16">
          <div class="container mx-auto relative px-4">
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-4">
                What you get
              </h2>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-link w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">AI resume reviews</h3>
                  <p class="text-muted-foreground">
                    See how well your resume fits the job and what to fix before applying.
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-layout-list w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <rect width="7" height="7" x="3" y="3" rx="1"></rect>
                      <rect width="7" height="7" x="3" y="14" rx="1"></rect>
                      <path d="M14 4h7"></path>
                      <path d="M14 9h7"></path>
                      <path d="M14 15h7"></path>
                      <path d="M14 20h7"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">Organized dashboard</h3>
                  <p class="text-muted-foreground">
                    Statuses, notes, due dates, and tags for every application.
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-sparkles w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
                      <path d="M20 3v4"></path>
                      <path d="M22 5h-4"></path>
                      <path d="M4 17v2"></path>
                      <path d="M5 18H3"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">Quick cover letters</h3>
                  <p class="text-muted-foreground">
                    Generated from the job post and your resume, not a generic template.
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-file-text w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
                      <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
                      <path d="M10 9H8"></path>
                      <path d="M16 13H8"></path>
                      <path d="M16 17H8"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">Resume storage</h3>
                  <p class="text-muted-foreground">
                    Upload your resumes and link them to applications.
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-upload w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="17 8 12 3 7 8"></polyline>
                      <line x1="12" x2="12" y1="3" y2="15"></line>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">Spreadsheet onboarding</h3>
                  <p class="text-muted-foreground">
                    Start in minutes, not hours.
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/20"
              >
                <div class="p-6 space-y-4">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-lg border border-primary/40 bg-linear-to-br from-primary/90 via-primary to-accent shadow-sm"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-link w-6 h-6 text-primary-foreground"
                      aria-hidden="true"
                    >
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                    </svg>
                  </div>
                  <h3 class="text-xl font-semibold">Paste-a-link import</h3>
                  <p class="text-muted-foreground">
                    Paste a job URL and the company, role, and details are filled in automatically.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Pricing Section -->
        <section id="pricing" class="relative py-24 scroll-mt-16">
          <div class="absolute inset-0 -z-10 bg-muted/40"></div>
          <div
            class="absolute inset-x-0 top-0 -z-10 h-px bg-linear-to-r from-transparent via-border to-transparent"
          ></div>
          <div class="container mx-auto relative px-4">
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-4">
                Free to track. Pay as you go for AI.
              </h2>
              <p class="text-xl text-muted-foreground">
                Track as many applications as you want for free. AI resume reviews and cover letters are pay-as-you-go. No monthly plans, no subscriptions.
              </p>
            </div>
            <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
              <!-- Free Card -->
              <div
                class="rounded-lg text-card-foreground border border-border/60 bg-card/80 shadow-sm backdrop-blur p-8 flex flex-col"
              >
                <div class="mb-6">
                  <h3 class="text-2xl font-bold">Free</h3>
                  <p class="text-muted-foreground mt-1">Track your entire job search</p>
                </div>
                <ul class="space-y-4 flex-grow">
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Unlimited application tracking</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Paste-a-link job import</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Notes, due dates, and tags</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Resume and document storage</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Spreadsheet/CSV import</span>
                  </li>
                </ul>
                <div class="mt-8">
                  <a
                    href="/app"
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-11 rounded-md px-8 w-full"
                  >
                    Get Started
                  </a>
                </div>
              </div>
              <!-- AI Features Card -->
              <div
                class="rounded-lg text-card-foreground border border-primary/40 bg-card/80 shadow-sm backdrop-blur p-8 flex flex-col"
              >
                <div class="mb-6">
                  <h3 class="text-2xl font-bold">AI Features</h3>
                  <p class="text-muted-foreground mt-1">Pay-as-you-go. No subscription.</p>
                </div>
                <ul class="space-y-4 flex-grow">
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>AI resume review from $0.12</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>AI cover letter from $0.12</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>Pay only when you use AI</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-5 h-5 text-primary mt-0.5 flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span>No subscriptions, no lock-in</span>
                  </li>
                </ul>
                <div class="mt-8">
                  <a
                    href="/app"
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-11 rounded-md px-8 w-full"
                  >
                    Start Free
                  </a>
                </div>
              </div>
            </div>
            <p class="text-center text-sm text-muted-foreground mt-8">
              Want full control? <a href="https://github.com/SergeyKhval/OpenApply" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Self-host with your own API keys</a>.
            </p>
          </div>
        </section>

        <!-- FAQ Section -->
        <section id="faq" class="relative py-24 scroll-mt-16">
          <div class="container mx-auto relative px-4">
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-4">
                Frequently Asked Questions
              </h2>
            </div>
            <div class="max-w-3xl mx-auto space-y-6">
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">How do coins work?</h3>
                <p class="text-muted-foreground">
                  Coins are only spent on AI features like resume reviews and cover letters. Tracking is free.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">How do AI resume reviews work?</h3>
                <p class="text-muted-foreground">
                  Pick a job and a resume, and we check the match. You get a score with specific suggestions on what to improve, ready in under a minute.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">Can I import my spreadsheet?</h3>
                <p class="text-muted-foreground">
                  Yes. Bring your CSV or export from your spreadsheet and you're set.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">How does paste-a-link work?</h3>
                <p class="text-muted-foreground">
                  Paste a URL from any job board and we scrape the page to fill in the company, role, and description automatically. Works with most popular boards. If a site is tricky, you can always add details manually.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">Can it write cover letters?</h3>
                <p class="text-muted-foreground">
                  Yes. Pick a job and a resume, and the AI generates a cover letter tailored to both. You can regenerate until you're happy with it.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">Is OpenApply open source?</h3>
                <p class="text-muted-foreground">
                  Yes. The entire codebase is on GitHub. You can self-host it with your own API keys if you prefer.
                </p>
              </div>
              <div class="rounded-lg border border-border/60 bg-card/80 backdrop-blur p-6">
                <h3 class="text-lg font-semibold mb-2">Which currencies do you support?</h3>
                <p class="text-muted-foreground">
                  Billing is pay‑as‑you‑go; currency and pricing are shown at checkout.
